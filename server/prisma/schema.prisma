generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CategoryStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CategoryDisplayType {
  DEFAULT
  COLLECTION
  LANDING
  HIDDEN
}

enum AttributeType {
  TEXT
  NUMBER
  BOOLEAN
  SELECT
  MULTI_SELECT
  DATE
  COLOR
  IMAGE
}

enum ProductStatus {
  DRAFT
  ACTIVE
  OUT_OF_STOCK
  ARCHIVED
}

enum ProductType {
  SIMPLE
  VARIABLE
  DIGITAL
  SERVICE
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  role          String    @default("customer")
  resetToken    String?   @unique
  resetTokenExp DateTime?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model ProductCategory {
  id       String            @id @default(uuid())
  parentId String?
  parent   ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children ProductCategory[] @relation("CategoryTree")

  name        String
  slug        String  @unique
  description String?
  image       String?
  icon        String?

  status      CategoryStatus      @default(ACTIVE)
  displayType CategoryDisplayType @default(DEFAULT)

  sortOrder Int      @default(0)
  level     Int      @default(0)
  path      String?
  pathIds   String[] @default([])

  seoTitle       String?
  seoDescription String?
  seoKeywords    String[] @default([])
  canonicalUrl   String?

  showInMenu     Boolean @default(true)
  showInHomepage Boolean @default(false)
  isFeatured     Boolean @default(false)

  metadata Json?
  filters  Json?

  products   ProductCategoryMap[]
  attributes CategoryAttribute[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([parentId])
  @@index([status])
  @@index([sortOrder])
  @@index([level])
  @@map("product_categories")
}

model CategoryAttribute {
  id         String          @id @default(uuid())
  categoryId String
  category   ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  name        String
  key         String
  type        AttributeType
  description String?

  required   Boolean @default(false)
  filterable Boolean @default(true)
  searchable Boolean @default(false)
  comparable Boolean @default(false)

  options   Json?
  unit      String?
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, key])
  @@index([categoryId])
  @@map("category_attributes")
}

model Product {
  id String @id @default(uuid())

  name             String
  slug             String  @unique
  sku              String? @unique
  description      String?
  shortDescription String?

  type   ProductType   @default(SIMPLE)
  status ProductStatus @default(DRAFT)

  price          Decimal  @db.Decimal(12, 2)
  compareAtPrice Decimal? @db.Decimal(12, 2)
  costPrice      Decimal? @db.Decimal(12, 2)

  thumbnailSmall String?
  thumbnailLarge String?
  images         String[] @default([])

  stockQuantity  Int     @default(0)
  trackStock     Boolean @default(true)
  allowBackorder Boolean @default(false)

  weight Decimal? @db.Decimal(10, 3)
  width  Decimal? @db.Decimal(10, 3)
  height Decimal? @db.Decimal(10, 3)
  length Decimal? @db.Decimal(10, 3)

  seoTitle       String?
  seoDescription String?
  seoKeywords    String[] @default([])

  isFeatured Boolean @default(false)
  sortOrder  Int     @default(0)
  soldCount  Int     @default(0)

  attributes Json?
  metadata   Json?

  categories ProductCategoryMap[]
  variants   ProductVariant[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@index([type])
  @@index([sortOrder])
  @@index([isFeatured])
  @@index([soldCount])
  @@map("products")
}

model ProductVariant {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  name String
  sku  String? @unique

  price          Decimal? @db.Decimal(12, 2)
  compareAtPrice Decimal? @db.Decimal(12, 2)
  costPrice      Decimal? @db.Decimal(12, 2)

  thumbnailSmall String?
  thumbnailLarge String?
  images         String[] @default([])

  stockQuantity  Int     @default(0)
  trackStock     Boolean @default(true)
  allowBackorder Boolean @default(false)

  options   Json?
  metadata  Json?
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([isActive])
  @@map("product_variants")
}

model ProductCategoryMap {
  productId  String
  categoryId String

  product  Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  category ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())

  @@id([productId, categoryId])
  @@index([categoryId])
  @@index([productId])
  @@map("product_category_maps")
}

enum BannerType {
  HERO
  BANNER
}

model Banner {
  id        String     @id @default(uuid())
  imageUrl  String
  linkUrl   String?
  altText   String?
  type      BannerType @default(BANNER)
  sortOrder Int        @default(0)
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("banners")
}
